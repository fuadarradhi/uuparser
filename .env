# =============================================================================
# uuparser — konfigurasi
#
# Salin menjadi .env lalu sesuaikan. HANYA berisi hal yang berbeda antar mesin.
# Parameter yang jawabannya sudah pasti (prompt OCR, ambang halaman-kosong,
# jeda sopan ke server, batas percobaan, jeda polling) adalah konstanta di
# kode, bukan di sini.
#
# Tidak ada flag CLI. Aksi admin (reset status, hapus tanda duplikat, parse
# ulang) lewat SQL langsung — lihat CATATAN-MIGRASI.md.
# =============================================================================

# --- DATABASE (wajib) --------------------------------------------------------
# Jalankan schema.sql sekali di database kosong sebelum service dijalankan.
DATABASE_URL=postgres://postgres:password@localhost:5432/uuparser

# --- MODEL (wajib ada berkasnya) ---------------------------------------------
# Dua model dijalankan di dalam proses lewat yzma/llama.cpp:
#   1. model VISI (OCR)   — membaca gambar halaman menjadi teks
#   2. model TEKS         — membaca halaman 1 (ini peraturan? nomor/tahun/
#                            daerah/tentang apa?) dan memperbaiki salah ketik
#
# Keduanya dimuat sekali dan dilepas bersamaan saat tidak ada pekerjaan.
# Perhatikan RAM: jumlah kedua model + KV cache harus muat sekaligus.
#
# Tata letak bawaan (tidak perlu diisi bila sudah sesuai):
#   ./models/ocr.gguf
#   ./models/ocr.mmproj.gguf
#   ./models/thinking.gguf
#   ./libs/           (libllama, libmtmd, dan pustaka pendukungnya)
#
# MODEL_PATH=./models/ocr.gguf
# MMPROJ_PATH=./models/ocr.mmproj.gguf
# THINKING_PATH=./models/thinking.gguf
# LIB_PATH=./libs
# VERBOSE=false

# --- MEMORI TERBATAS ---------------------------------------------------------
# Bawaan (false): kedua model menempati memori BERSAMAAN selama masih ada
# antrian, lalu dilepas bersamaan saat antrian habis. Ini paling cepat.
#
# Setel true bila proses BERHENTI MENDADAK TANPA PESAN saat model kedua
# dimuat — itu tanda sistem menghentikannya paksa karena kehabisan memori
# (periksa: `echo $?` bernilai 137, atau `dmesg | grep -i kill`).
#
# Pada mode ini kedua model bergantian: model visi dilepas sebelum model teks
# dipakai, dan sebaliknya. Harganya nyata — tiap halaman memuat ulang model,
# menambah puluhan detik per halaman. Matikan lagi begitu RAM mencukupi.
# LOW_MEMORY=false

# --- PENYELAMAT: FORMAT PERCAKAPAN ------------------------------------------
# Biarkan kosong pada keadaan normal. Model GGUF umumnya menyertakan format
# percakapannya sendiri dan itu yang dipakai.
#
# Isi HANYA bila log memberi peringatan bahwa model tidak menyertakan chat
# template, atau bila jawaban model kacau. Nilai yang lazim: gemma, llama3,
# chatml, mistral. Memakai format yang salah tidak menimbulkan galat, hanya
# menurunkan mutu jawaban — jadi periksa log saat pertama kali menjalankan.
# CHAT_TEMPLATE=

# --- PROMPT ------------------------------------------------------------------
# Folder berisi gate.md, identity.md, dan penetapan.md — pertanyaan untuk model
# teks, sengaja dipecah satu pertanyaan per berkas karena model kecil lebih
# andal menjawab satu hal daripada banyak hal sekaligus. Dibaca saat mulai;
# mengubah isinya cukup jalankan ulang, tidak perlu membangun ulang binari.
# PROMPT_DIR=./prompts

# --- RENDER ------------------------------------------------------------------
# DPI dipilih OTOMATIS per halaman lewat skor ketajaman (varians Laplacian —
# metode umum & murah untuk deteksi blur), bukan satu angka tetap untuk
# seluruh dokumen (2026-07-22). Halaman jelas dirender di DPI_JELAS SEKALIGUS
# dipakai sebagai "probe" pengukur ketajaman — kalau skornya sudah cukup,
# TIDAK ADA render ulang (paling murah, paling sering: dokumen bersih).
# Halaman kurang tajam dirender ULANG di DPI_SEDANG; yang benar-benar blur di
# DPI_BLUR.
#
# BLUR_AMBANG_JELAS/BLUR_AMBANG_SEDANG HARUS DIKALIBRASI terhadap korpus Anda
# — nilai bawaan di bawah cuma titik awal, BUKAN hasil pengukuran (beda dari
# nilai bawaan lain di berkas ini). Cara kalibrasi: jalankan dulu dengan
# nilai bawaan, lalu:
#   grep 'blur_score=' log/info.log
# Amati sebaran skornya — dokumen yang Anda tahu jelas seharusnya berada di
# atas BLUR_AMBANG_JELAS, yang blur di bawah BLUR_AMBANG_SEDANG. Sesuaikan
# kedua ambang itu sampai pembagiannya cocok dengan penilaian Anda sendiri
# atas berkas-berkas itu.
# DPI_JELAS=100
# DPI_SEDANG=150
# DPI_BLUR=200
# BLUR_AMBANG_JELAS=5e8
# BLUR_AMBANG_SEDANG=5e7

# --- CAKUPAN -------------------------------------------------------------
# TAHUN menyaring dokumen SAAT DIDAFTARKAN dari sumber, berdasarkan tahunnya
# (metadata JDIH, dipakai sebatas urutan — bukan sumber kebenaran identitas).
# Mendukung operator eksplisit: "=2023" (persis tahun itu saja), ">=2023"
# (minimal), ">2020", "<=2019", "<2019". Tanpa operator (mis. "2023" polos)
# diperlakukan sebagai ">=". Kosong = tanpa saringan sama sekali.
#
# Berguna untuk memperkecil cakupan uji coba parser secara sengaja: mulai
# dari rentang tahun kecil, perbesar bertahap, sambil mengamati tahun berapa
# parser sudah bagus dan tahun berapa masih perlu perbaikan (mis. nanti bisa
# bercabang: tahun >= X pakai satu strategi parse, tahun < X pakai yang lain).
#
# Saat diisi: dokumen TANPA metadata tahun dari sumber IKUT disaring — tidak
# didaftarkan. Kalau TAHUN diisi, harus benar-benar ada tahun yang memenuhi
# operatornya, bukan lolos karena tidak diketahui. Hanya saat TAHUN kosong
# (tanpa saringan sama sekali) dokumen tanpa tahun boleh masuk.
TAHUN="=2025"

# MAX_PAGE membatasi jumlah halaman yang BENAR-BENAR di-OCR/diurai per
# dokumen — sisanya diabaikan begitu saja, seolah dokumen itu hanya
# sepanjang MAX_PAGE halaman. Khusus masa debug: supaya satu peraturan yang
# tebal tidak menyita seluruh waktu uji coba sampai peraturan lain tak
# sempat diperiksa. 0 = tanpa batas (matikan setelah masa debug selesai).
MAX_PAGE=5

# MIN_PAGE menolak dokumen sebagai "bukan peraturan" TANPA di-OCR sama
# sekali bila jumlah halaman ASLI-nya (sebelum dipotong MAX_PAGE) kurang
# dari ini — berdasarkan temuan nyata: banyak berkas sependek itu ternyata
# cuma sampul/pengumuman, bukan naskah peraturan utuh. 0 = tanpa batas
# minimum.
MIN_PAGE=2

# --- DEBUG -----------------------------------------------------------------
# DEBUG_RESULT=true membuat setiap dokumen menulis ke DEBUG_DIR/<id_dokumen>/:
#   ocr.txt          — semua teks hasil OCR, per halaman, gampang ditempel
#   thinking.txt     — hanya bila ada panggilan model teks (gate/identity/
#                      penetapan) — prompt, masukan, jawaban mentah model
#   parse.txt        — hasil parse (pohon Bab/Bagian/Pasal/Diktum/Ayat),
#                      gampang ditempel ke percakapan
#   parse_tree.json  — pohon yang sama tapi berbentuk JSON parent-child asli
#                      (dari parent_id yang sama persis dipakai insert ke DB)
#
# Tujuannya sekadar mempermudah menyalin hasil OCR/parse untuk dikirim ke
# Claude untuk dipelajari — BUKAN untuk dinyalakan terus-menerus (menulis
# berkas tambahan per dokumen). Nyalakan sebentar saat memang perlu
# meninjau, matikan lagi sesudahnya.
DEBUG_RESULT=true

# DEBUG_DIR: folder tujuan berkas debug di atas. SENGAJA folder terpisah
# dari DATA_DIR (bukan data/debug/) — data/* seluruhnya di-gitignore,
# sedangkan folder ini TIDAK, supaya isinya bisa di-commit ke git bila
# memang ingin disertakan (mis. buat ditinjau bersama Claude).
# DEBUG_DIR=debug

# --- DATA & LOG --------------------------------------------------------------
# Semua PDF disimpan di SATU folder (data/pdf/) dengan nama = hash isinya.
# Teks OCR, hasil perbaikan, dan hasil parse sepenuhnya di Postgres.
# DATA_DIR=data
#
# LOG_DIR memuat dua berkas: info.log (seluruh catatan) dan error.log
# (peringatan & kegagalan saja). Konsol sengaja HANYA menampilkan baris
# kemajuan, sehingga baris itu tidak pernah tertimpa catatan lain — jadi
# saat ada yang janggal, periksa kedua berkas ini.
# LOG_DIR=log
