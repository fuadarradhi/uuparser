# =============================================================================
# uuparser — konfigurasi
#
# Salin berkas ini menjadi .env lalu sesuaikan. Baris yang dikomentari
# menunjukkan nilai bawaannya; hanya bagian MODEL yang wajib diisi.
#
# Variabel lingkungan proses menimpa isi berkas ini, berguna untuk systemd atau
# kontainer tanpa menyunting berkas.
# =============================================================================


# --- MODEL (wajib) -----------------------------------------------------------
#
# Model dijalankan langsung di dalam proses lewat yzma/llama.cpp. Tidak ada
# server inferensi dan tidak ada permintaan keluar; satu-satunya lalu lintas
# jaringan aplikasi ini adalah pengunduhan PDF.
#
# Model dimuat sekali lalu dipakai untuk seluruh dokumen, dan dilepas dari
# memori ketika tidak ada lagi yang perlu di-OCR.

# Bawaan mengikuti tata letak di sebelah binari, sehingga service dapat langsung
# dijalankan tanpa mengisi apa pun di bawah ini:
#
#   ./uuparser
#   ./models/ocr.gguf
#   ./models/ocr.mmproj.gguf
#   ./libs/            (libllama, libmtmd, dan pustaka pendukungnya)
#   ./log/error.log
#
# Isi hanya bila berkas Anda berada di tempat lain.

# Berkas model GGUF.
#MODEL_PATH=./models/ocr.gguf

# Berkas proyektor multimodal (mmproj). WAJIB untuk model visi — tanpa ini
# gambar tidak dapat diproses sama sekali.
#MMPROJ_PATH=./models/ocr.mmproj.gguf

# Folder berisi libllama dan libmtmd. Dapat juga diatur lewat variabel
# lingkungan YZMA_LIB.
#LIB_PATH=./libs

# Folder berkas log. Kegagalan dicatat permanen ke <LOG_DIR>/error.log, penting
# saat berjalan sebagai service systemd.
#LOG_DIR=./log

# Tampilkan log llama.cpp.
#VERBOSE=false

# Parameter inferensi lain (suhu, top-k, top-p, ukuran konteks, sampler) tidak
# disediakan di sini. Suhu dipatok 0 agar hasil OCR dapat diulang persis, dan
# pada suhu 0 parameter pengambilan token lain tidak berpengaruh.


# --- Prompt ------------------------------------------------------------------

# GLM-OCR hanya mengenali beberapa prompt: "Text Recognition:",
# "Table Recognition:", "Figure Recognition:", "Formula Recognition:".
#OCR_PROMPT=Text Recognition:

# Batas token keluaran per halaman — pengaman bila model tidak berhenti sendiri.
#OCR_MAX_TOKENS=2048


# --- Sumber data -------------------------------------------------------------

# Daftar endpoint /integrasi JDIH, dipisah koma. Data tiap sumber disimpan pada
# folder terpisah yang namanya diturunkan dari nama host.
ENDPOINTS=http://jdih.acehprov.go.id/integrasi

# Folder akar penyimpanan.
#DATA_DIR=data

# Jeda antar siklus pemeriksaan dokumen baru.
#INTERVAL=60m


# --- Render halaman ----------------------------------------------------------

# Resolusi rasterisasi. Menentukan ketajaman huruf, jadi berpengaruh langsung
# pada ketelitian pembacaan nomor pasal dan ayat.
#DPI=200

# Potong margin kosong halaman. SANGAT DISARANKAN tetap aktif: memangkas banyak
# piksel TANPA mengecilkan huruf. Pemotongan bersifat agresif — halaman A4 yang
# hanya berisi satu baris terpotong menjadi seukuran baris itu saja.
#AUTO_CROP=true

# Halaman pertama yang di-OCR untuk menguji apakah berkas ini benar peraturan.
# Bila tak ada tandanya, sisa halaman tidak di-OCR sama sekali.
#PROBE_PAGES=5

# Halaman dengan proporsi piksel gelap di bawah nilai ini dianggap kosong dan
# tidak dikirim ke model.
#BLANK_INK=0.0004

# Simpan gambar halaman yang dikirim ke model, ke data/<sumber>/png/<slug>/.
#SAVE_PNG=false


# --- Unduhan & ketahanan -----------------------------------------------------

# Jeda antar permintaan unduh, agar sopan terhadap server pemerintah.
#DELAY_MS=1500

# Batas percobaan per dokumen sebelum dilewati (0 = tanpa batas). Mencegah satu
# PDF rusak dicoba ulang tiap siklus selamanya.
#MAX_ATTEMPTS=3

# Unduh SEMUA PDF lebih dulu sebelum OCR. Bawaannya per dokumen (unduh, OCR,
# parse, lanjut) agar hasil pertama muncul cepat.
#DOWNLOAD_FIRST=false


# --- Catatan -----------------------------------------------------------------
#
# Pembatasan jumlah dokumen saat uji coba diatur lewat flag baris perintah, agar
# nilai uji coba tidak tertinggal dan diam-diam membatasi service produksi:
#
#   ./uuparser -once -limit 5
#   ./uuparser -once -ids 1,2,76
