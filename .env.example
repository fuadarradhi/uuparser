# =============================================================================
# uuparser — konfigurasi
#
# Salin berkas ini menjadi .env lalu sesuaikan. HANYA berisi hal yang benar-
# benar berbeda antar instalasi (lokasi database, lokasi berkas model, lokasi
# folder data/log). Parameter yang jawabannya sudah pasti (prompt OCR, DPI,
# ambang halaman-kosong, jeda sopan ke server JDIH, batas percobaan, jeda
# polling tiap worker) SENGAJA konstanta di kode (internal/extractor,
# internal/pipeline) — bukan di sini, supaya tidak ada tombol yang bisa
# "diutak-atik jadi rusak" tanpa alasan.
#
# Tidak ada flag CLI. Service ini murni jalan dari .env — lihat
# CATATAN-MIGRASI.md untuk cara melakukan aksi admin (reset/approve/reject
# dokumen) lewat SQL langsung.
# =============================================================================

# --- DATABASE (wajib) ---------------------------------------------------------
#
# Postgres PRODUKSI (bukan staging) — jalankan schema.sql sekali di database
# kosong sebelum service ini pertama kali dijalankan.
DATABASE_URL=postgres://user:password@localhost:5432/uuparser

# --- MODEL (wajib) -------------------------------------------------------------
#
# Model dijalankan langsung di dalam proses lewat yzma/llama.cpp. Tidak ada
# server inferensi dan tidak ada permintaan keluar; satu-satunya lalu lintas
# jaringan aplikasi ini adalah pengunduhan PDF.
#
# Bawaan mengikuti tata letak di sebelah binari, sehingga service dapat langsung
# dijalankan tanpa mengisi apa pun di bawah ini:
#
#   ./uuparser
#   ./models/ocr.gguf
#   ./models/ocr.mmproj.gguf
#   ./libs/            (libllama, libmtmd, dan pustaka pendukungnya)
#   ./log/error.log
#
# Isi hanya bila berkas Anda berada di tempat lain.
# MODEL_PATH=./models/ocr.gguf
# MMPROJ_PATH=./models/ocr.mmproj.gguf
# LIB_PATH=./libs
# VERBOSE=false

# --- DATA & LOG ----------------------------------------------------------------
#
# Satu-satunya berkas yang tetap hidup di disk selain log adalah PDF sumber
# (dipakai untuk pratinjau) — data/<sumber>/pdf/<slug>.pdf. Teks OCR dan hasil
# parse SEPENUHNYA di Postgres, tidak ada berkas perantara.
# DATA_DIR=data
# LOG_DIR=log
